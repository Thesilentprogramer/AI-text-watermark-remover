# --- Free paraphrase (recommended) ---
# Get a free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMMA_API_MODEL=gemma-4-26b-a4b-it
# api = Gemini free tier (best quality) | heuristic = no key, instant, weaker
PARAPHRASE_BACKEND=api
# auto = single API call first, chunk only if output is truncated
GEMMA_API_CHUNKING=auto
GEMMA_SINGLE_CALL_MAX_CHARS=8000

# --- Optional ---
HF_TOKEN=your_huggingface_token_here
MODEL_ID=google/gemma-4-E2B-it
ENABLE_PERPLEXITY=true
ENABLE_LOCAL_GEMMA=false
FORCE_ATTACK=false
PORT=8000
HOST=0.0.0.0
